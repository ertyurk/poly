# ============================================================================
# Environment Variables — polymarket-bot
# ============================================================================
# Copy this file to .env and fill in your values.

# --------------------------------------------------------------------------
# Logging
# --------------------------------------------------------------------------
# Controls tracing verbosity.
# Values: trace, debug, info, warn, error
RUST_LOG=polymarket_bot=info

# --------------------------------------------------------------------------
# Polymarket API Keys (required for live trading only)
# --------------------------------------------------------------------------
# Not needed for --paper-trade mode (uses public endpoints only).

# Your Polymarket CLOB API key
POLYMARKET_API_KEY=

# Your Polymarket API secret (base64-encoded)
POLYMARKET_API_SECRET=

# Your Polymarket passphrase
POLYMARKET_PASSPHRASE=

# Your Ethereum wallet private key for EIP-712 order signing (hex, no 0x prefix)
# NEVER commit this. Keep it in .env only.
PRIVATE_KEY=
