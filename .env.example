# ============================================================================
# Environment Variables — polymarket-bot
# ============================================================================
# Copy this file to .env and fill in your values.

# --------------------------------------------------------------------------
# Logging
# --------------------------------------------------------------------------
# Controls tracing verbosity.
# Values: trace, debug, info, warn, error
RUST_LOG=polymarket_bot=info

# --------------------------------------------------------------------------
# Polymarket (required for live trading only)
# --------------------------------------------------------------------------
# Not needed for --paper-trade mode (uses public endpoints only).
# The official SDK derives API credentials from the private key automatically.

# Your Ethereum wallet private key (hex, with or without 0x prefix)
# NEVER commit this. Keep it in .env only.
PRIVATE_KEY=
